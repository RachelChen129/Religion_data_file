knitr::opts_chunk$set(echo = TRUE)
library(readr)
library(dplyr)
# import data
data <- read_csv("Test.csv")
data <- data |> select(-REGION, -DENOMREC2, -FAMILY, -PROTFAM, -CURREL2, -FRMREL2, -SPREL, -SPREL2, -SPBORNFINAL, -KIDS4ANDUNDERREC, -KIDS5TO12REC, -KIDS13TO17REC, -CITIZEN)
knitr::opts_chunk$set(echo = TRUE)
library(readr)
library(dplyr)
# import data
data <- read_csv("Test.csv")
knitr::opts_chunk$set(echo = TRUE)
library(readr)
library(dplyr)
library(tidyverse)
# import data
data <- read_csv("Test.csv")
data <- data |> mutate(CURREL = factor(CURREL, levels=c(1000,10000,20000,30000,40001,40002,50000,60000,70000,80000,90001,90002,100000,900000),
labels=c("Protestant","Catholic", "Mormon", "Orthodox", "JW", "Other Christian", "Jewish", "Muslim", "Buddhist", "Hindu", "Other Religion", "Other Faith", "Unaffiliated", "Uninterpretable")))
data$SPIRPER[data$SPIRPER == 99] <- 5
data_subset1 <- data |>
filter(CURREL %in% c("Protestant", "Catholic", "Unaffiliated"))
data_subset2 <- data |>
filter(CURREL %in% c("Mormon", "Jewish", "Other Faith"))
data_subset3 <- data |>
filter(CURREL %in% c("Orthodox", "JW", "Other Christian", "Muslim", "Buddhist", "Hindu", "Other Religion",  "Uninterpretable"))
ggplot(data = data_subset1, aes(x=SPIRPER))+
geom_histogram()+
facet_wrap(~CURREL)
ggplot(data = data_subset2, aes(x=SPIRPER))+
geom_histogram()+
facet_wrap(~CURREL)
ggplot(data = data_subset3, aes(x=SPIRPER))+
geom_histogram()+
facet_wrap(~CURREL)
data$RELPER[data$RELPER == 99] <- 5
data_subset1 <- data |>
filter(CURREL %in% c("Protestant", "Catholic", "Unaffiliated"))
data_subset2 <- data |>
filter(CURREL %in% c("Mormon", "Jewish", "Other Faith"))
data_subset3 <- data |>
filter(CURREL %in% c("Orthodox", "JW", "Other Christian", "Muslim", "Buddhist", "Hindu", "Other Religion",  "Uninterpretable"))
ggplot(data = data_subset1, aes(x=RELPER))+
geom_histogram()+
facet_wrap(~CURREL)
ggplot(data = data_subset2, aes(x=RELPER))+
geom_histogram()+
facet_wrap(~CURREL)
ggplot(data = data_subset3, aes(x=RELPER))+
geom_histogram()+
facet_wrap(~CURREL)
anova_model <- aov(RELPER ~ CURREL, data=data)
summary(anova_model)
cor(data$RELPER, data$SPIRPER, use="complete.obs")
model1 <- lm(RELPER ~ SPIRPER, data=data)
summary(model1)
model2 <- lm(RELPER ~ ATTNDPERRLS + PRAY + PRAC_B + PRAC_D, data=data)
summary(model2)
final_model <- lm(RELPER ~ SPIRPER + ATTNDPERRLS + PRAY + PRAC_B + PRAC_D + GOD + HVN + HLL + CURREL, data=data)
summary(final_model)
plot(final_model)
cor(data$RELPER, data$SPIRPER, use="complete.obs")
model1 <- lm(RELPER ~ SPIRPER, data=data)
summary(model1)
final_model <- lm(RELPER ~ SPIRPER + ATTNDPERRLS + PRAY + PRAC_B + PRAC_D + GOD + HVN + HLL + CURREL, data=data)
summary(final_model)
ggplot(data = final_model) +
geom_point(aes(y = .resid, x = .fitted)) +
labs(x = "Fitted Values", y = "Residuals")
model2 <- lm(RELPER ~ ATTNDPERRLS + PRAY + PRAC_B + PRAC_D, data=data)
summary(model2)
ggplot(data = mlb21) +
geom_point(aes(x = SPIRPER, y = RELPER)) +
geom_smooth(method = "lm", aes(x = SPIRPER, y = RELPER), color = 'green')
ggplot(data = data) +
geom_point(aes(x = SPIRPER, y = RELPER)) +
geom_smooth(method = "lm", aes(x = SPIRPER, y = RELPER), color = 'green')
ggplot(data, aes(x = factor(SPIRPER), y = RELPER)) +
geom_boxplot()
ggplot(data, aes(x = factor(SPIRPER), y = RELPER)) +
geom_boxplot()
data |>
group_by(SPIRPER) |>
summarize(mean_rel = mean(RELPER, na.rm=TRUE)) |>
ggplot(aes(x = SPIRPER, y = mean_rel)) +
geom_point() +
geom_line()
ggplot(data = data) +
geom_jitter(aes(x = SPIRPER, y = RELPER), width = 0.2, height = 0.2, alpha = 0.3) +
geom_smooth(method = "lm", aes(x = SPIRPER, y = RELPER), color = 'green')
ggplot(data, aes(x = factor(SPIRPER), y = RELPER)) +
geom_boxplot()
data |>
group_by(SPIRPER) |>
summarize(mean_rel = mean(RELPER, na.rm=TRUE)) |>
ggplot(aes(x = SPIRPER, y = mean_rel)) +
geom_point() +
geom_line()
data$predicted <- predict(model2)
ggplot(data, aes(x = predicted, y = RELPER)) +
geom_point(alpha = 0.3) +
geom_smooth(method = "lm", color = "blue") +
labs(title = "Observed vs Predicted Religiosity",
x = "Predicted Religiosity",
y = "Observed Religiosity")
library(broom)
library(ggplot2)
tidy_model <- tidy(model2)
ggplot(tidy_model[-1,], aes(x = estimate, y = term)) +
geom_point() +
geom_errorbarh(aes(xmin = estimate - 2*std.error, xmax = estimate + 2*std.error)) +
labs(title = "Effect of Behavioral Variables on Religiosity",
x = "Estimated Effect",
y = "Predictor")
data$predicted <- predict(model2)
ggplot(data, aes(x = predicted, y = RELPER)) +
geom_point(alpha = 0.3) +
geom_smooth(method = "lm", color = "blue") +
labs(title = "Observed vs Predicted Religiosity",
x = "Predicted Religiosity",
y = "Observed Religiosity")
data$predicted <- predict(model2)
ggplot(data, aes(x = predicted, y = RELPER)) +
geom_point(alpha = 0.3) +
geom_smooth(method = "lm", color = "blue") +
labs(title = "Observed vs Predicted Religiosity",
x = "Predicted Religiosity",
y = "Observed Religiosity")
plot(anova_model)

catholic_polly2 <- lm(RELPER ~ CHNG_A + CHNG_B + DIVRELPOP + DIVRACPOP + QB2C,
data = filter(data_clean3, CURREL == "Catholic"))
protestant_polly2 <- lm(RELPER ~ CHNG_A + CHNG_B + DIVRELPOP + DIVRACPOP + QB2C,
data = filter(data_clean3, CURREL == "Protestant"))
unaffiliated_polly2 <- lm(RELPER ~ CHNG_A + CHNG_B + DIVRELPOP + DIVRACPOP + QB2C,
data = filter(data_clean3, CURREL == "Unaffiliated"))
library(broom)
library(dplyr)
library(ggplot2)
all_models <- bind_rows(
tidy(catholic_polly2, conf.int = TRUE) %>% mutate(Group = "Catholic"),
tidy(protestant_polly2, conf.int = TRUE) %>% mutate(Group = "Protestant"),
tidy(unaffiliated_polly2, conf.int = TRUE) %>% mutate(Group = "Unaffiliated")
) %>%
filter(term != "(Intercept)")
ggplot(all_models, aes(x = estimate, y = term, color = Group)) +
geom_vline(xintercept = 0, linetype = "dashed", color = "gray60") +
geom_point(position = position_dodge(width = 0.6), size = 3) +
geom_errorbarh(aes(xmin = conf.low, xmax = conf.high),
position = position_dodge(width = 0.6), height = 0.3) +
labs(title = "Social Predictors of Religiosity by Tradition",
subtitle = "Comparing effect sizes of diversity and social change",
x = "Coefficient Estimate (Impact on RELPER)",
y = "Predictor Variable") +
theme_minimal() +
scale_color_brewer(palette = "Set1")
data_clean3 <- subset(data,
RELPER != 99 &
CHNG_A != 99 &
CHNG_B != 99 &
DIVRELPOP != 99 &
DIVRACPOP != 99 &
QB2C != 99)
catholic_polly2 <- lm(RELPER ~ CHNG_A + CHNG_B + DIVRELPOP + DIVRACPOP + QB2C,
data = subset(data_clean3, CURREL == "Catholic"))
protestant_polly2 <- lm(RELPER ~ CHNG_A + CHNG_B + DIVRELPOP + DIVRACPOP + QB2C,
data = subset(data_clean3, CURREL == "Protestant"))
unaffiliated_polly2 <- lm(RELPER ~ CHNG_A + CHNG_B + DIVRELPOP + DIVRACPOP + QB2C,
data = subset(data_clean3, CURREL == "Unaffiliated"))
summary(catholic_polly2)
summary(protestant_polly2)
summary(unaffiliated_polly2)

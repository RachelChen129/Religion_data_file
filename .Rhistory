unaffiliated_polly <- lm(Religiosity ~ Abortion_Legality + Gay_Marriage_Support +
Homosexuality_Acceptance + Transgender_Acceptance + Immigrant_Impact + Relig_Diversity +
Racial_Diversity + Environmental_Regulation, data = unaffiliated_pol)
summary(catholic_polly)
summary(protestant_polly)
summary(unaffiliated_polly)
library(broom)
library(dplyr)
library(ggplot2)
catholic_results    <- tidy(catholic_polly, conf.int = TRUE) %>% mutate(Group = "Catholic")
protestant_results  <- tidy(protestant_polly, conf.int = TRUE) %>% mutate(Group = "Protestant")
unaffiliated_results <- tidy(unaffiliated_polly, conf.int = TRUE) %>% mutate(Group = "Unaffiliated")
coef_df <- bind_rows(catholic_results, protestant_results, unaffiliated_results) %>%
filter(term != "(Intercept)") # Remove the intercept to focus on variables
ggplot(coef_df, aes(x = estimate, y = term, color = Group)) +
geom_vline(xintercept = 0, linetype = "dashed", color = "gray50") + # Added for significance context
geom_point(position = position_dodge(width = 0.5), size = 3) +
geom_errorbarh(aes(xmin = conf.low, xmax = conf.high),
position = position_dodge(width = 0.5), height = 0.2) +
labs(
title = "Behavioral Predictors of Religiosity",
subtitle = "Comparing Catholics, Protestants, and the Unaffiliated",
x = "Effect on Religiosity (Regression Coefficient)",
y = "Behavioral Variables",
color = "Religious Group"
) +
theme_minimal()
catholic_pol <- data_clean |> filter(CURREL == "Catholic")
catholic_polly <- lm(Religiosity ~ Abortion_Legality + Gay_Marriage_Support +
Homosexuality_Acceptance + Transgender_Acceptance + Immigrant_Impact + Relig_Diversity +
Racial_Diversity + Environmental_Regulation, data = catholic_pol)
protestant_pol <- data_clean |> filter(CURREL == "Protestant")
protestant_polly <- lm(Religiosity ~ Abortion_Legality  + Gay_Marriage_Support + Homosexuality_Acceptance + Transgender_Acceptance + Immigrant_Impact + Relig_Diversity + Racial_Diversity + Environmental_Regulation, data = protestant_pol)
unaffiliated_pol <- data_clean |> filter(CURREL == "Unaffiliated")
unaffiliated_polly <- lm(Religiosity ~ Abortion_Legality  + Gay_Marriage_Support + Homosexuality_Acceptance + Transgender_Acceptance + Immigrant_Impact + Relig_Diversity + Racial_Diversity + Environmental_Regulation, data = unaffiliated_pol)
summary(catholic_polly)
summary(protestant_polly)
summary(unaffiliated_polly)
coef_df <- bind_rows(catholic_results, protestant_results, unaffiliated_results) %>%
filter(term != "(Intercept)") # Remove the intercept to focus on variables
ggplot(coef_df, aes(x = estimate, y = term, color = Group)) +
geom_vline(xintercept = 0, linetype = "dashed", color = "gray50") + # Added for significance context
geom_point(position = position_dodge(width = 0.5), size = 3) +
geom_errorbarh(aes(xmin = conf.low, xmax = conf.high),
position = position_dodge(width = 0.5), height = 0.2) +
labs(
title = "Behavioral Predictors of Religiosity",
subtitle = "Comparing Catholics, Protestants, and the Unaffiliated",
x = "Effect on Religiosity (Regression Coefficient)",
y = "Behavioral Variables",
color = "Religious Group"
) +
theme_minimal()

filter(
RELPER    != 99,
ABRTLGL   != 99,
GAYMARR   != 99,
QB2A      != 99,
CHNG_C    != 99,
CHNG_A    != 99,
DIVRELPOP != 99,
DIVRACPOP != 99,
QB2C      != 99
) |>
rename(
Religiosity            = RELPER,
Abortion_Legality      = ABRTLGL,
Gay_Marriage_Support   = GAYMARR,
Homosexuality_Acceptance     = QB2A,
Transgender_Acceptance = CHNG_C,
Immigrant_Impact       = CHNG_A,
Relig_Diversity        = DIVRELPOP,
Racial_Diversity       = DIVRACPOP,
Environmental_Regulation       = QB2C
)
model3 <- lm(Religiosity ~ Abortion_Legality  + Gay_Marriage_Support + Homosexuality_Acceptance + Transgender_Acceptance, data = data_clean)
summary(model3)
data_clean_spir <- subset(data_clean, SPIRPER != 99 & Abortion_Legality  != 99 & Gay_Marriage_Support != 99 & Homosexuality_Acceptance != 99 & Transgender_Acceptance !=99)
data_spir <- lm(SPIRPER ~ Abortion_Legality  + Gay_Marriage_Support + Homosexuality_Acceptance + Transgender_Acceptance, data = data_clean)
summary(data_spir)
m1_resids <- augment(model3) %>%
mutate(Model = "Religiosity Model")
m2_resids <- augment(data_spir) %>%
mutate(Model = "Spirituality Model")
all_resids <- bind_rows(m1_resids, m2_resids)
ggplot(all_resids, aes(x = .resid)) +
geom_histogram(aes(y = after_stat(density)),
bins = 30, fill = "gray90", color = "white") +
stat_function(
fun = dnorm,
args = list(
mean = mean(all_resids$.resid, na.rm = TRUE),
sd = sd(all_resids$.resid, na.rm = TRUE)
),
color = "blue",
linewidth = 1.5
) +
facet_wrap(~ Model, scales = "free") +
labs(
title = "Residual Normality Check",
subtitle = "Comparing Error Distributions for Religiosity vs. Spirituality Models",
x = "Residual (Prediction Error)",
y = "Density"
) +
theme_minimal()

c(RELPER, ABRTLGL, GAYMARR, QB2A, CHNG_C, CHNG_A, DIVRELPOP, DIVRACPOP, QB2C),
~na_if(., 99)
)) |>
rename(
Religiosity              = RELPER,
Abortion_Legality        = ABRTLGL,
Gay_Marriage_Support     = GAYMARR,
Homosexuality_Acceptance = QB2A,
Transgender_Acceptance   = CHNG_C,
Immigrant_Impact         = CHNG_A,
Relig_Diversity          = DIVRELPOP,
Racial_Diversity         = DIVRACPOP,
Environmental_Regulation = QB2C
)
library(broom)
library(dplyr)
library(ggplot2)
# 1. Tidy both models and label them so they have a "Group"
# This turns the math into the 'estimate' and 'term' columns ggplot needs
plot_data <- bind_rows(
tidy(polly_pol, conf.int = TRUE) %>% mutate(Group = "Social/Sexual Issues"),
tidy(polly_pol2, conf.int = TRUE) %>% mutate(Group = "Diversity/Environment")
) %>%
filter(term != "(Intercept)")
# 2. Now the ggplot will work perfectly
ggplot(plot_data, aes(x = estimate, y = term, color = Group)) +
geom_vline(xintercept = 0, linetype = "dashed", color = "gray") +
geom_point(position = position_dodge(width = 0.5), size = 3) +
geom_errorbarh(aes(xmin = conf.low, xmax = conf.high),
position = position_dodge(width = 0.5), height = 0.2) +
labs(
title = "Comparison of Predictors of Religiosity",
subtitle = "Social vs. Environmental Factors",
x = "Effect on Religiosity (Coefficient)",
y = "Variables",
color = "Model Category"
) +
theme_minimal()

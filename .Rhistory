library(dplyr)
data_clean <- data |>
mutate(across(
c(RELPER, ABRTLGL, GAYMARR, QB2A, CHNG_C, CHNG_A, DIVRELPOP, DIVRACPOP, QB2C),
~na_if(., 99)
)) |>
rename(
Religiosity              = RELPER,
Abortion_Legality        = ABRTLGL,
Gay_Marriage_Support     = GAYMARR,
Homosexuality_Acceptance = QB2A,
Transgender_Acceptance   = CHNG_C,
Immigrant_Impact         = CHNG_A,
Relig_Diversity          = DIVRELPOP,
Racial_Diversity         = DIVRACPOP,
Environmental_Regulation = QB2C
)
polly_pol <- lm(Religiosity ~ Abortion_Legality + Gay_Marriage_Support +
Homosexuality_Acceptance + Transgender_Acceptance +
Immigrant_Impact + Relig_Diversity +
Racial_Diversity + Environmental_Regulation,
data = data_clean)
# 2. CONVERT THE MODEL TO A TABLE (The "Fix")
# This creates the 'estimate', 'term', 'conf.low', and 'conf.high' columns needed for ggplot
polly_plot_df <- tidy(polly_pol, conf.int = TRUE) %>%
filter(term != "(Intercept)") %>%
# Categorize them so they are color-coded in the single chart
mutate(Group = case_when(
term %in% c("Abortion_Legality", "Gay_Marriage_Support",
"Homosexuality_Acceptance", "Transgender_Acceptance") ~ "Social/Sexual Issues",
TRUE ~ "Diversity/Environmental"
))
# 3. THE VISUALIZATION
ggplot(polly_plot_df, aes(x = estimate, y = term, color = Group)) +
geom_vline(xintercept = 0, linetype = "dashed", color = "gray50") +
geom_point(size = 3) +
geom_errorbarh(aes(xmin = conf.low, xmax = conf.high), height = 0.2) +
labs(
title = "Predictors of Religiosity: Full Model Comparison",
subtitle = "All variables visualized in a single regression forest plot",
x = "Effect Size (Coefficient Estimate)",
y = "Variables",
color = "Category"
) +
theme_minimal()
